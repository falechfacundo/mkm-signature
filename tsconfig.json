{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@config/*": ["src/config/*"],
      "@data/*": ["src/data/*"],
      "@lib/*": ["src/lib/*"],
      "@blocks/*": ["src/blocks/*"],
      "@components/*": ["src/components/*"]
    }
  }
}