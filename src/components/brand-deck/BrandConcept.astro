---
import { SITE } from '@config/site';
---

<section class="slide">
  <span class="slide-number">02 / Brand Concept</span>
  <div class="concept-content">
    <p class="concept-text">
      MKM Signature redefines mobile barbering as an act of precision and ritual.
      Each visit transforms a routine grooming session into a personal style
      experience, delivered with discretion and craftsmanship in the comfort of
      your home.
    </p>
    <div class="concept-meta">
      <div class="meta-item">
        <span class="meta-label">Service</span>
        <span class="meta-value">Mobile barbering</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Coverage</span>
        <span class="meta-value">{SITE.coverZone}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Approach</span>
        <span class="meta-value">Premium at-home grooming</span>
      </div>
    </div>
  </div>
</section>

<style>
  .concept-content {
    max-width: 900px;
  }

  .concept-text {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(28px, 3.5vw, 48px);
    line-height: 1.3;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    margin-bottom: 60px;
  }

  .concept-meta {
    display: flex;
    gap: 60px;
    padding-top: 32px;
    border-top: 1px solid var(--bg-border);
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .meta-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .meta-value {
    font-size: 15px;
    font-weight: 400;
    color: var(--text-secondary);
  }

  @media print {
    .concept-text {
      color: #111 !important;
    }
    .meta-label {
      color: #666 !important;
    }
    .meta-value {
      color: #444 !important;
    }
    .concept-meta {
      border-top-color: #ddd !important;
    }
  }

  @media screen and (max-width: 768px) {
    .concept-meta {
      flex-direction: column;
      gap: 24px;
    }
  }
</style>
