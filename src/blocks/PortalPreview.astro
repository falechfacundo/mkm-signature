---
import PortalPreviewMock from '@components/react/PortalPreviewMock';
import { SITE } from '@config/site';
---

<section id="portal" class="py-16 md:py-24" style="background:var(--bg-secondary)">
  <div class="max-w-6xl mx-auto px-6">
    <header class="scroll-reveal-bottom">
      <span class="mono text-xs tracking-widest uppercase" style="color:var(--accent)">Sistema de gestion</span>
      <h2 class="text-4xl mt-2" style="font-family:var(--font-display)">Tu proyecto, organizado desde el dia uno</h2>
      <p class="mt-3 max-w-2xl" style="color:var(--text-secondary)">
        No mas actualizaciones perdidas en WhatsApp. Todo en un portal dedicado: roadmap, archivos,
        pagos y comunicacion centralizada.
      </p>
    </header>

    <PortalPreviewMock client:visible />

    <div class="mt-8 flex flex-col md:flex-row gap-4 items-start md:items-center">
      <p class="mono text-sm" style="color:var(--text-muted)">Acceso disponible en portal.ad-astra.me al confirmar el proyecto</p>
      <a
        href={SITE.portalUrl}
        target="_blank"
        class="mono text-sm underline-offset-4 hover:underline"
        style="color:var(--accent)"
      >
        Ver el portal -&gt;
      </a>
    </div>
  </div>
</section>
