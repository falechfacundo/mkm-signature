---
import { getFAQs } from '@data/faq';
import FAQAccordion from '@components/react/FAQAccordion';
import SectionSpringIn from '@components/react/SectionSpringIn';
import type { ServiceConfig } from '@config/services';

interface Props {
  service: ServiceConfig;
}

const { service } = Astro.props as Props;
const faqs = getFAQs(service.id);
---

<section id="faq" class="py-16 md:py-24" style="background:var(--bg-secondary)">
  <div class="max-w-6xl mx-auto px-6">
    <SectionSpringIn client:visible>
    <div class="mb-12 md:mb-14">
      <span
        class="mono inline-flex items-center text-[10px] md:text-xs tracking-[0.2em] uppercase px-3 py-1.5 rounded-full"
        style="
          color:var(--accent);
          background:color-mix(in srgb, var(--accent) 10%, transparent);
          border:1px solid color-mix(in srgb, var(--accent) 30%, transparent);
        "
      >
        FAQ
      </span>
      <h2 class="text-4xl md:text-5xl mt-4 leading-tight" style="font-family:var(--font-display)">Preguntas frecuentes</h2>
      <p class="mt-4 max-w-2xl text-sm md:text-base" style="color:var(--text-secondary)">
        Las dudas mas comunes, respondidas antes de que las hagas.
      </p>
    </div>
    </SectionSpringIn>

    <FAQAccordion client:visible items={faqs} />
  </div>
</section>
