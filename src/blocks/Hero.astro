---
import type { HubParams } from '@lib/params';
import type { ServiceConfig } from '@config/services';
import { SITE } from '@config/site';
import Button from '@components/ui/Button.astro';
import Badge from '@components/ui/Badge.astro';

interface Props {
  params: HubParams;
  service: ServiceConfig;
}

const { params, service } = Astro.props as Props;
const headlineSuffix = params.client ? ` para ${params.client}.` : '';
---

<section id="hero" class="relative overflow-hidden min-h-screen py-16 md:py-24" style="background:var(--bg-primary)">
  <div class="noise absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <div
    class="absolute -top-32 -right-16 w-md h-112 rounded-full pointer-events-none"
    style="background:radial-gradient(circle, rgba(174,53,255,0.14) 0%, rgba(174,53,255,0.03) 42%, transparent 72%)"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-6xl mx-auto px-6 min-h-screen flex items-center py-32">
    <div class="max-w-3xl flex flex-col gap-6">
      <span class="mono text-sm tracking-widest uppercase scroll-reveal-bottom stagger-1" style="color:var(--accent)">
        Ad Astra - Digital Studio
      </span>

      <h1
        class="scroll-reveal-bottom stagger-2 leading-tight"
        style="font-size:clamp(3rem,7vw,6rem); font-family:var(--font-display); color:var(--text-primary)"
      >
        {service.headline}
        {headlineSuffix && <span style="color:var(--accent)">{headlineSuffix}</span>}
      </h1>

      <p class="scroll-reveal-bottom stagger-3 text-xl leading-relaxed max-w-2xl" style="color:var(--text-secondary)">
        {service.subheadline}
      </p>

      <div class="scroll-reveal-bottom stagger-4 flex gap-3 flex-wrap">
        <Badge>
          <svg aria-hidden="true" viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 12l5 5L20 6"></path>
          </svg>
          Entrega garantizada
        </Badge>
        <Badge>
          <svg aria-hidden="true" viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M12 7v5l3 2"></path>
          </svg>
          30 dias de soporte
        </Badge>
        <Badge>
          <svg aria-hidden="true" viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 5h16v14H4z"></path>
            <path d="M8 9h8"></path>
            <path d="M8 13h5"></path>
          </svg>
          Portal de proyecto incluido
        </Badge>
      </div>

      <div class="scroll-reveal-bottom stagger-5 flex gap-4 flex-wrap mt-2">
        <Button href={SITE.workanaCta} target="_blank" class="px-8 py-4 text-base">
          {service.ctaLabel}
        </Button>
        <Button variant="ghost" href={SITE.portfolioUrl} target="_blank" class="px-6 py-4 text-base">
          Ver portfolio -&gt;
        </Button>
      </div>
    </div>
  </div>

  <div
    class="absolute right-0 top-1/2 -translate-y-1/2 w-96 h-96 opacity-20 hidden lg:block pointer-events-none"
    style="background-image:radial-gradient(var(--bg-border) 1px, transparent 1px); background-size:16px 16px"
    aria-hidden="true"
  ></div>
</section>
