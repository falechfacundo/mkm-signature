---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { tags, category } = post.data;

const categoryLabels: Record<string, string> = {
  tendencias: 'Tendencias',
  cuidado: 'Cuidado',
  estilo: 'Estilo',
  domicilio: 'A domicilio',
};
---

<article class="blog-content">
  <div class="blog-content__body">
    <slot />
  </div>

  <footer class="blog-content__footer">
    <div class="blog-content__tags">
      <span class="blog-content__tags-label">Tags:</span>
      {tags.map((tag) => (
        <span class="blog-content__tag">#{tag}</span>
      ))}
    </div>
    <a href={`/blog/categoria/${category}`} class="blog-content__category-link">
      Ver más posts sobre {categoryLabels[category] ?? category} →
    </a>
  </footer>
</article>

<style is:global>
  .blog-content {
    max-width: 52rem;
    margin: 3rem auto;
    padding: 0 1.5rem;
  }
  .blog-content__body {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .blog-content__body :global(h2) {
    color: var(--text-primary);
    font-size: 1.75rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
    scroll-margin-top: 80px;
  }
  .blog-content__body :global(h3) {
    color: var(--text-primary);
    font-size: 1.35rem;
    font-weight: 700;
    margin: 2rem 0 0.75rem;
    line-height: 1.3;
    scroll-margin-top: 80px;
  }
  .blog-content__body :global(p) {
    margin: 0 0 1.25rem;
  }
  .blog-content__body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: rgba(212, 167, 44, 0.4);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s ease;
  }
  .blog-content__body :global(a:hover) {
    text-decoration-color: var(--accent);
  }
  .blog-content__body :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }
  .blog-content__body :global(ul),
  .blog-content__body :global(ol) {
    margin: 0 0 1.5rem;
    padding-left: 1.5rem;
  }
  .blog-content__body :global(li) {
    margin-bottom: 0.5rem;
  }
  .blog-content__body :global(blockquote) {
    border-left: 3px solid var(--accent);
    margin: 1.5rem 0;
    padding: 0.5rem 0 0.5rem 1.25rem;
    color: var(--text-primary);
    font-style: italic;
    background: var(--accent-muted);
    border-radius: 0 8px 8px 0;
  }
  .blog-content__body :global(code) {
    background: var(--bg-surface);
    color: var(--accent);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .blog-content__body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
    background: var(--bg-surface);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--bg-border);
  }
  .blog-content__body :global(thead) {
    background: var(--bg-secondary);
  }
  .blog-content__body :global(th),
  .blog-content__body :global(td) {
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--bg-border);
  }
  .blog-content__body :global(th) {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .blog-content__body :global(tr:last-child td) {
    border-bottom: none;
  }
  .blog-content__body :global(.heading-anchor) {
    color: inherit;
    text-decoration: none;
  }
  .blog-content__body :global(.heading-anchor:hover) {
    color: var(--accent);
  }
  .blog-content__footer {
    max-width: 52rem;
    margin: 3rem auto 0;
    padding: 2rem 1.5rem 0;
    border-top: 1px solid var(--bg-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .blog-content__tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }
  .blog-content__tags-label {
    color: var(--text-muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }
  .blog-content__tag {
    color: var(--text-secondary);
    background: var(--bg-surface);
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    font-size: 0.75rem;
    border: 1px solid var(--bg-border);
  }
  .blog-content__category-link {
    color: var(--accent);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .blog-content__category-link:hover {
    text-decoration: underline;
  }
</style>
