---
import SectionSpringIn from '@components/react/SectionSpringIn';

const channels = ['Portal del proyecto', 'Email', 'Chat interno', 'Videocall'];

const rituals = [
  'Kickoff inicial con alcance y riesgos',
  'Update async cada 48-72hs',
  'Revision de hitos con feedback',
  'Cierre con handoff y soporte',
];

const kpis = [
  { label: 'SLA respuesta', value: '<2hs' },
  { label: 'Frecuencia update', value: '48-72hs' },
  { label: 'Trazabilidad', value: '100%' },
  { label: 'Canales activos', value: '4' },
];
---

<section id="comunicacion" class="py-16 md:py-24" style="background:var(--bg-primary)">
  <div class="max-w-6xl mx-auto px-6">
    <SectionSpringIn client:visible>
    <header>
      <span class="mono text-xs tracking-widest uppercase" style="color:var(--accent)">Comunicacion</span>
      <h2 class="text-4xl mt-2" style="font-family:var(--font-display)">Todo documentado. Nada se pierde.</h2>
      <p class="mt-3" style="color:var(--text-secondary)">
        La comunicacion del proyecto tiene estructura. Sin depender de que alguien responda un WhatsApp.
      </p>
    </header>
    </SectionSpringIn>

    <div class="grid grid-cols-1 md:grid-cols-6 xl:grid-cols-12 gap-4 mt-12">
      <SectionSpringIn client:visible className="md:col-span-4 xl:col-span-7">
      <article
        class="rounded-2xl p-6"
        style="
          position:relative;
          overflow:hidden;
          border:1px solid color-mix(in srgb, var(--accent) 45%, transparent);
          background:linear-gradient(165deg, rgba(26,26,26,0.98) 0%, rgba(18,15,26,0.98) 65%, rgba(12,12,12,0.98) 100%);
          box-shadow:0 18px 34px -24px rgba(0,0,0,0.9);
        "
      >
        <div
          aria-hidden="true"
          style="
            position:absolute;
            inset:0;
            pointer-events:none;
            background:radial-gradient(circle at 86% 12%, rgba(174,53,255,0.18) 0%, rgba(174,53,255,0.0) 42%);
          "
        ></div>
        <div style="position:relative; z-index:1; display:flex; flex-direction:column; gap:1rem;">
          <span class="mono" style="font-size:0.66rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--accent)">
            Hub de comunicacion
          </span>
          <h3 class="text-2xl md:text-3xl" style="margin:0; font-family:var(--font-display); line-height:1.1; color:var(--text-primary)">
            Un solo lugar para decidir, seguir y cerrar.
          </h3>
          <p class="text-sm md:text-base" style="margin:0; color:var(--text-secondary); line-height:1.7; max-width:48ch;">
            Nada queda suelto: decisiones, bloqueos y avances se registran en el mismo flujo. Evitamos perdida de contexto y tiempos muertos.
          </p>
          <div class="flex flex-wrap gap-2.5 mt-1">
            {channels.map((channel) => (
              <span
                class="mono"
                style="
                  font-size:0.66rem;
                  letter-spacing:0.08em;
                  text-transform:uppercase;
                  color:var(--text-secondary);
                  border:1px solid var(--bg-border);
                  border-radius:999px;
                  padding:0.32rem 0.68rem;
                  background:var(--bg-surface);
                "
              >
                {channel}
              </span>
            ))}
          </div>
        </div>
      </article>
      </SectionSpringIn>

      <SectionSpringIn client:visible delay={0.05} className="md:col-span-2 xl:col-span-5">
      <article
        class="rounded-2xl p-5"
        style="
          border:1px solid var(--bg-border);
          background:linear-gradient(180deg, rgba(24,24,24,0.96) 0%, rgba(17,17,17,0.96) 100%);
          box-shadow:0 14px 26px -22px rgba(0,0,0,0.9);
        "
      >
        <span class="mono" style="font-size:0.66rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--text-muted)">
          KPIs operativos
        </span>
        <div class="grid grid-cols-2 gap-2.5 mt-3">
          {kpis.map((kpi) => (
            <div
              style="
                border:1px solid var(--bg-border);
                border-radius:12px;
                padding:0.75rem;
                background:var(--bg-surface);
              "
            >
              <p class="mono" style="margin:0; font-size:0.62rem; letter-spacing:0.08em; color:var(--text-muted); text-transform:uppercase;">
                {kpi.label}
              </p>
              <p style="margin:0.28rem 0 0; color:var(--text-primary); font-size:1.08rem; font-weight:700;">{kpi.value}</p>
            </div>
          ))}
        </div>
      </article>
      </SectionSpringIn>

      <SectionSpringIn client:visible delay={0.1} className="md:col-span-3 xl:col-span-4">
      <article
        class="rounded-2xl p-5"
        style="
          border:1px solid color-mix(in srgb, var(--turquesa-500) 35%, transparent);
          background:linear-gradient(180deg, rgba(14,28,26,0.96) 0%, rgba(12,16,16,0.96) 100%);
          box-shadow:0 14px 26px -22px rgba(0,0,0,0.9);
        "
      >
        <span class="mono" style="font-size:0.66rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--turquesa-500)">SLA</span>
        <h3 class="text-3xl" style="margin:0.35rem 0 0; font-family:var(--font-display); color:var(--text-primary)">&lt; 2hs</h3>
        <p style="margin:0.42rem 0 0; color:var(--text-secondary); line-height:1.65; font-size:0.9rem;">
          Tiempo objetivo de primera respuesta durante horario operativo. Si hay bloqueo critico, se prioriza en el mismo dia.
        </p>
      </article>
      </SectionSpringIn>

      <SectionSpringIn client:visible delay={0.15} className="md:col-span-3 xl:col-span-4">
      <article
        class="rounded-2xl p-5"
        style="
          border:1px solid var(--bg-border);
          background:linear-gradient(180deg, rgba(23,23,23,0.96) 0%, rgba(16,16,16,0.96) 100%);
          box-shadow:0 14px 26px -22px rgba(0,0,0,0.9);
        "
      >
        <span class="mono" style="font-size:0.66rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--text-muted)">Canales</span>
        <ul class="mt-3 space-y-2.5">
          {channels.map((channel) => (
            <li class="flex items-center gap-2.5" style="color:var(--text-secondary); font-size:0.9rem;">
              <span style="width:6px; height:6px; border-radius:999px; background:var(--accent); flex-shrink:0;"></span>
              <span>{channel}</span>
            </li>
          ))}
        </ul>
      </article>
      </SectionSpringIn>

      <SectionSpringIn client:visible delay={0.2} className="md:col-span-6 xl:col-span-4">
      <article
        class="rounded-2xl p-5"
        style="
          border:1px solid var(--bg-border);
          background:linear-gradient(180deg, rgba(22,22,22,0.96) 0%, rgba(14,14,14,0.96) 100%);
          box-shadow:0 14px 26px -22px rgba(0,0,0,0.9);
        "
      >
        <span class="mono" style="font-size:0.66rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--accent)">Rituales</span>
        <ol class="mt-3 space-y-2.5">
          {rituals.map((ritual, index) => (
            <li class="flex gap-2.5" style="color:var(--text-secondary); font-size:0.9rem; line-height:1.55;">
              <span class="mono" style="color:var(--accent); font-size:0.66rem; margin-top:0.2rem;">0{index + 1}</span>
              <span>{ritual}</span>
            </li>
          ))}
        </ol>
      </article>
      </SectionSpringIn>
    </div>
  </div>
</section>
