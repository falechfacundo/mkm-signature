---
import SectionSpringIn from '@components/react/SectionSpringIn';

const cards = [
  {
    title: 'Updates cada 48-72hs',
    desc: 'Progreso visible en el portal sin que tengas que preguntar.',
    icon: 'clock',
    color: 'var(--accent)',
  },
  {
    title: 'Canal directo en el proyecto',
    desc: 'Mensajes organizados por proyecto. Sin mezclar conversaciones.',
    icon: 'message',
    color: 'var(--accent)',
  },
  {
    title: 'Todo documentado',
    desc: 'Decisiones, cambios y acuerdos quedan registrados. Sin malentendidos.',
    icon: 'file',
    color: 'var(--accent)',
  },
  {
    title: 'Videocalls si aplica',
    desc: 'Para revisiones o definiciones que son mas claras en vivo.',
    icon: 'video',
    color: 'var(--turquesa-500)',
  },
];
---

<section id="comunicacion" class="py-16 md:py-24" style="background:var(--bg-primary)">
  <div class="max-w-6xl mx-auto px-6">
    <SectionSpringIn client:visible>
    <header>
      <span class="mono text-xs tracking-widest uppercase" style="color:var(--accent)">Comunicacion</span>
      <h2 class="text-4xl mt-2" style="font-family:var(--font-display)">Todo documentado. Nada se pierde.</h2>
      <p class="mt-3" style="color:var(--text-secondary)">
        La comunicacion del proyecto tiene estructura. Sin depender de que alguien responda un WhatsApp.
      </p>
    </header>
    </SectionSpringIn>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mt-12">
      {cards.map((card, index) => {
        const isSecondary = card.icon === 'video';
        const accentSoft = isSecondary ? 'rgba(0, 209, 191, 0.2)' : 'rgba(174, 53, 255, 0.2)';

        return (
        <SectionSpringIn client:visible delay={index * 0.08}>
        <article
          class="group rounded-2xl p-6 transition-transform duration-300 ease-out hover:-translate-y-1"
          style={`
            position:relative;
            overflow:hidden;
            border:1px solid var(--bg-border);
            background:linear-gradient(180deg, rgba(26,26,26,0.96) 0%, rgba(17,17,17,0.96) 100%);
            box-shadow:0 14px 26px -22px rgba(0,0,0,0.9);
          `}
        >
          <div
            class="opacity-30 transition-opacity duration-300 group-hover:opacity-100"
            style={`
              position:absolute;
              top:0;
              left:0;
              right:0;
              height:2px;
              background:${isSecondary
                ? 'linear-gradient(90deg, transparent 0%, var(--turquesa-500) 35%, transparent 100%)'
                : 'linear-gradient(90deg, transparent 0%, var(--accent) 35%, transparent 100%)'};
            `}
            aria-hidden="true"
          ></div>

          <div
            class="opacity-0 transition-opacity duration-300 group-hover:opacity-100"
            style={`
              position:absolute;
              inset:0;
              pointer-events:none;
              background:radial-gradient(circle at 95% 0%, ${accentSoft} 0%, rgba(0,0,0,0) 46%);
            `}
            aria-hidden="true"
          ></div>

          <div style="position:relative; z-index:1;">
            <div class="flex items-center justify-between mb-4">
              <span class="mono" style="font-size:0.66rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--text-muted)">
                Comunicacion {(index + 1).toString().padStart(2, '0')}
              </span>
              <span
                style={`
                  width:2.35rem;
                  height:2.35rem;
                  border-radius:0.75rem;
                  display:grid;
                  place-items:center;
                  border:1px solid ${accentSoft};
                  background:${isSecondary
                    ? 'linear-gradient(135deg, rgba(0,209,191,0.1) 0%, rgba(0,209,191,0.02) 100%)'
                    : 'linear-gradient(135deg, rgba(174,53,255,0.1) 0%, rgba(174,53,255,0.02) 100%)'};
                `}
              >
                {card.icon === 'clock' && (
                  <svg aria-hidden="true" viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke={card.color} stroke-width="2">
                    <circle cx="12" cy="12" r="9"></circle>
                    <path d="M12 7v5l3 2"></path>
                  </svg>
                )}
                {card.icon === 'message' && (
                  <svg aria-hidden="true" viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke={card.color} stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H8l-5 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                  </svg>
                )}
                {card.icon === 'file' && (
                  <svg aria-hidden="true" viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke={card.color} stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <path d="M14 2v6h6"></path>
                  </svg>
                )}
                {card.icon === 'video' && (
                  <svg aria-hidden="true" viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke={card.color} stroke-width="2">
                    <rect x="2" y="7" width="14" height="10" rx="2"></rect>
                    <path d="m16 10 6-3v10l-6-3z"></path>
                  </svg>
                )}
              </span>
            </div>

            <h3 class="text-lg" style="margin:0 0 0.45rem; font-family:var(--font-display); line-height:1.3; color:var(--text-primary)">
              {card.title}
            </h3>
            <p class="text-sm" style="margin:0; color:var(--text-secondary); line-height:1.65">{card.desc}</p>
          </div>
        </article>
        </SectionSpringIn>
      )})}
    </div>
  </div>
</section>
