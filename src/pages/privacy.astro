---
import '../styles/global.css';
import { SITE } from '@config/site';
---

<!doctype html>
<html lang="es" style="background-color: #080c14">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Política de Privacidad de MKM Signature" />
    <title>Privacidad — MKM Signature</title>
    <link rel="icon" type="image/svg+xml" href="/logo-cara.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body style="background: #080c14; color: #f0efe8; font-family: Montserrat, sans-serif; margin: 0; padding: 0;">
    <main style="max-width: 700px; margin: 0 auto; padding: 4rem 1.5rem 6rem;">
      <a href="/" style="display: inline-flex; align-items: center; gap: 0.5rem; color: #d4a72c; text-decoration: none; font-size: 0.82rem; font-weight: 600; margin-bottom: 2.5rem;">
        ← Volver al inicio
      </a>

      <article>
        <h1 style="font-size: 2.2rem; font-weight: 700; margin: 0 0 0.3rem; line-height: 1.15; color: #f0efe8;">
          Política de Privacidad
        </h1>
        <p style="color: #4d5f85; font-size: 0.82rem; margin: 0 0 2.5rem;">
          Última actualización: junio 2026
        </p>

        <section style="margin-bottom: 2rem;">
          <h2 style="font-size: 1.15rem; font-weight: 600; margin: 0 0 0.6rem; color: #f0efe8;">
            ¿Qué datos recolectamos?
          </h2>
          <p style="color: #9ba9c9; font-size: 0.9rem; line-height: 1.7; margin: 0;">
            Solamente los datos necesarios para coordinar tu turno: nombre, número de teléfono e información básica de la reserva (servicio, zona, horario).
          </p>
        </section>

        <section style="margin-bottom: 2rem;">
          <h2 style="font-size: 1.15rem; font-weight: 600; margin: 0 0 0.6rem; color: #f0efe8;">
            ¿Para qué usamos tus datos?
          </h2>
          <p style="color: #9ba9c9; font-size: 0.9rem; line-height: 1.7; margin: 0;">
            Únicamente para agendar tu turno, contactarte si es necesario y brindarte el servicio. La comunicación es siempre por WhatsApp.
          </p>
        </section>

        <section style="margin-bottom: 2rem;">
          <h2 style="font-size: 1.15rem; font-weight: 600; margin: 0 0 0.6rem; color: #f0efe8;">
            ¿Compartimos tus datos con terceros?
          </h2>
          <p style="color: #9ba9c9; font-size: 0.9rem; line-height: 1.7; margin: 0;">
            No. No vendemos, alquilamos ni compartimos tu información con nadie.
          </p>
        </section>

        <section style="margin-bottom: 2rem;">
          <h2 style="font-size: 1.15rem; font-weight: 600; margin: 0 0 0.6rem; color: #f0efe8;">
            Comunicación
          </h2>
          <p style="color: #9ba9c9; font-size: 0.9rem; line-height: 1.7; margin: 0;">
            WhatsApp es nuestro único canal de comunicación con los clientes. No realizamos llamadas ni enviamos mensajes por otras plataformas.
          </p>
        </section>

        <section style="margin-bottom: 2rem;">
          <h2 style="font-size: 1.15rem; font-weight: 600; margin: 0 0 0.6rem; color: #f0efe8;">
            Contacto
          </h2>
          <p style="color: #9ba9c9; font-size: 0.9rem; line-height: 1.7; margin: 0;">
            Si tenés preguntas sobre esta política, podés contactarme por WhatsApp o escribir a <a href="mailto:{SITE.contactEmail}" style="color: #d4a72c;">{SITE.contactEmail}</a>.
          </p>
        </section>
      </article>
    </main>
  </body>
</html>
