---
const logos = [
  { src: '/logo-corona.png', label: 'Primary — Positive', w: 280, h: 280 },
  { src: '/logo-corona-negativo.png', label: 'Primary — Negative', w: 280, h: 280 },
  { src: '/logo-cara.png', label: 'Isotype — Positive', w: 200, h: 200 },
  { src: '/logo-cara-negativo.png', label: 'Isotype — Negative', w: 200, h: 200 },
];
---

<section class="slide">
  <span class="slide-number">03 / Logo System</span>
  <div class="logo-grid">
    {logos.map((logo) => (
      <div class="logo-item">
        <div class={`logo-visual ${logo.label.includes('Negative') ? 'bg-dark' : 'bg-light'}`}>
          <img src={logo.src} alt={logo.label} width={logo.w} height={logo.h} class="logo-img" />
        </div>
        <span class="logo-label">{logo.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .logo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px 80px;
    max-width: 1100px;
  }

  .logo-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .logo-visual {
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 380px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    padding: 48px;
  }

  .logo-visual.bg-light {
    background: #f5f4ef;
  }

  .logo-visual.bg-dark {
    background: #0a0e18;
  }

  .logo-img {
    width: 70%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .logo-label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-align: center;
  }

  @media print {
    .logo-visual.bg-light {
      background: #f5f4ef !important;
    }
    .logo-visual.bg-dark {
      background: #0a0e18 !important;
    }
    .logo-label {
      color: #666 !important;
    }
  }

  @media screen and (max-width: 768px) {
    .logo-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
