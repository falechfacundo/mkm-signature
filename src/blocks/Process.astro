---
import { PROCESS_STEPS } from '@data/process';
---

<section id="proceso" class="py-16 md:py-24" style="background:var(--bg-secondary)">
  <div class="max-w-6xl mx-auto px-6">
    <div class="scroll-reveal-bottom">
      <span class="mono text-xs tracking-widest uppercase" style="color:var(--accent)">Proceso</span>
      <h2 class="text-4xl mt-2" style="font-family:var(--font-display); color:var(--text-primary)">Como trabajamos</h2>
      <p class="mt-3" style="color:var(--text-secondary)">Estructura clara de inicio a fin. Sin sorpresas.</p>
    </div>

    <div class="relative mt-16">
      <div
        class="hidden lg:block absolute top-0 left-0 right-0 h-px"
        style="background:linear-gradient(90deg, var(--bg-border) 0%, var(--accent) 50%, var(--bg-border) 100%)"
      ></div>

      <div class="flex flex-col lg:flex-row gap-8 lg:gap-6">
        {PROCESS_STEPS.map((step, index) => (
          <article class={`flex-1 flex flex-col gap-3 scroll-reveal-bottom stagger-${Math.min(index + 1, 6)}`}>
            <span class="mono text-xs" style="color:var(--accent)">{step.number}</span>
            <h3 class="text-xl" style="font-family:var(--font-display); color:var(--text-primary)">{step.title}</h3>
            <p class="text-sm" style="color:var(--text-secondary)">{step.desc}</p>
            <span
              class="mono text-xs rounded px-2 py-1 w-fit"
              style="background:var(--bg-surface); color:var(--text-muted)"
            >
              {step.duration}
            </span>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
