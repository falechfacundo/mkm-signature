---
import BookingCalendar from '@components/react/BookingCalendar';
---

<section id="reservar" style="background:var(--bg-secondary); padding:6rem 0">
  <div style="max-width:72rem; margin:0 auto; padding:0 1.5rem">
    <div style="text-align:center; margin-bottom:2.5rem">
      <div style="display:flex; align-items:center; justify-content:center; gap:0.6rem; margin-bottom:0.5rem">
        <img src="/logo-cara-blanco.svg" alt="" style="display:block; width:22px; height:auto" />
        <span style="color:var(--accent); text-transform:uppercase; letter-spacing:0.12em; font-size:0.72rem">MKM Signature</span>
      </div>
      <h2 style="margin-top:0.65rem; margin-bottom:0.75rem; font-size:clamp(2rem,4vw,2.8rem)">
        Elegí día y horario
      </h2>
      <p style="margin:0 auto; color:var(--text-secondary); font-size:1.05rem; max-width:36rem">
        Seleccioná cuándo querés que vaya a tu domicilio y te confirmo por WhatsApp.
      </p>
    </div>

    <BookingCalendar client:load />
  </div>
</section>
